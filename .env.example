# Segredo do NextAuth (gere com: openssl rand -base64 32)
NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Usuários do dashboard (JSON). role: "admin" ou "user"
APP_USERS=[{"u":"admin","p":"troque","role":"admin"},{"u":"agentes","p":"troque","role":"user"}]

# Service Account do Google (compartilhe as planilhas com este e-mail)
GOOGLE_SERVICE_ACCOUNT_EMAIL=conta@projeto.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# IDs das planilhas separados por vírgula
SPREADSHEET_IDS=id-planilha-1,id-planilha-2
